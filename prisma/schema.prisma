generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql" url = env("DATABASE_URL") }

enum AutomationMode { draft_only assisted autopilot }
enum MemberRole { owner admin staff }
enum IntegrationType { whatsapp twilio_sms gmail google_calendar google_maps stripe }
enum IntegrationStatus { not_connected connected error mock }
enum ContactLabel { customer supplier staff personal_ignore spam unknown }
enum MessageChannel { whatsapp sms email manual }
enum MessageDirection { inbound outbound }
enum ReplyWindow { open template_required unknown }
enum PricingStrategy { fixed_price package_price from_price callout_plus_hourly quote_after_photos owner_required }
enum LeadStatus { new qualifying quoted follow_up_due booking_pending booked completed payment_pending paid review_requested lost }
enum Urgency { low medium high emergency }
enum PriceType { fixed from estimate manual }
enum QuoteStatus { draft sent accepted rejected expired }
enum ApprovalType { send_reply confirm_quote book_job send_invoice send_review_request follow_up resolve_complaint }
enum RiskLevel { low medium high }
enum ApprovalStatus { pending approved rejected edited expired }
enum OutboundStatus { queued sending sent failed retrying cancelled }
enum JobStatus { scheduled completed reschedule_needed cancelled issue }
enum PaymentStatus { unpaid paid_cash paid_card paid_bank paid_stripe invoice_needed invoice_sent overdue }
enum InvoiceStatus { draft sent paid overdue void }
enum ReviewStatus { draft queued sent clicked completed skipped }
enum ActorType { system ai owner customer }

model User { id String @id @default(cuid()) email String @unique name String? passwordHash String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt businesses Business[] members BusinessMember[] }
model Business { id String @id @default(cuid()) ownerId String name String tradeType String tone String @default("friendly and direct") basePostcode String? baseAddress String? baseLat Float? baseLng Float? serviceRadiusMiles Int @default(25) extendedRadiusMiles Int @default(40) defaultCurrency String @default("GBP") reviewLink String? invoicePaymentTerms String @default("Payment due within 7 days") workingHours Json automationMode AutomationMode @default(assisted) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt owner User @relation(fields:[ownerId], references:[id]) members BusinessMember[] integrations Integration[] contacts Contact[] messages Message[] rawWebhookEvents RawWebhookEvent[] services Service[] priceRules PriceRule[] leads Lead[] quotes Quote[] jobs Job[] approvals ApprovalRequest[] outboundMessages OutboundMessage[] invoices Invoice[] reviewRequests ReviewRequest[] activityLogs ActivityLog[] }
model BusinessMember { id String @id @default(cuid()) businessId String userId String role MemberRole @default(staff) business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) user User @relation(fields:[userId], references:[id], onDelete:Cascade) @@unique([businessId,userId]) }
model Integration { id String @id @default(cuid()) businessId String type IntegrationType status IntegrationStatus @default(not_connected) accessToken String? refreshToken String? externalAccountId String? externalPhoneNumberId String? metadata Json? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) @@unique([businessId,type]) }
model Contact { id String @id @default(cuid()) businessId String name String? phone String? email String? address String? postcode String? lat Float? lng Float? label ContactLabel @default(unknown) sourceChannel MessageChannel? notes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) messages Message[] leads Lead[] jobs Job[] outboundMessages OutboundMessage[] invoices Invoice[] reviewRequests ReviewRequest[] }
model Message { id String @id @default(cuid()) businessId String contactId String? leadId String? jobId String? channel MessageChannel direction MessageDirection externalMessageId String? senderHandle String recipientHandle String? bodyText String attachments Json @default("[]") threadId String? replyWindow ReplyWindow @default(unknown) rawPayload Json? providerStatus String? sentAt DateTime? receivedAt DateTime? createdAt DateTime @default(now()) business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) contact Contact? @relation(fields:[contactId], references:[id]) lead Lead? @relation(fields:[leadId], references:[id]) job Job? @relation(fields:[jobId], references:[id]) @@unique([businessId, channel, externalMessageId]) }
model RawWebhookEvent { id String @id @default(cuid()) businessId String? channel MessageChannel providerEventId String? payload Json headers Json? processedAt DateTime? createdAt DateTime @default(now()) business Business? @relation(fields:[businessId], references:[id]) }
model Service { id String @id @default(cuid()) businessId String tradeType String name String description String? category String? active Boolean @default(true) requiredFields Json @default("[]") optionalFields Json @default("[]") durationMinutes Int @default(60) setupMinutes Int @default(0) cleanupMinutes Int @default(0) pricingStrategy PricingStrategy autoQuoteAllowed Boolean @default(false) autoBookAllowed Boolean @default(false) riskFlags Json @default("[]") handoffRules Json? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) priceRules PriceRule[] leads Lead[] quotes Quote[] jobs Job[] }
model PriceRule { id String @id @default(cuid()) businessId String serviceId String name String pricingStrategy PricingStrategy basePrice Decimal? fromPrice Decimal? hourlyRate Decimal? calloutFee Decimal? currency String @default("GBP") modifiers Json @default("[]") conditions Json? active Boolean @default(true) createdAt DateTime @default(now()) updatedAt DateTime @updatedAt business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) service Service @relation(fields:[serviceId], references:[id], onDelete:Cascade) }
model Lead { id String @id @default(cuid()) businessId String contactId String? sourceChannel MessageChannel status LeadStatus @default(new) classification String intent String? tradeCategory String? serviceId String? serviceMatchConfidence Float @default(0) qualityScore Float @default(0) urgency Urgency @default(medium) locationText String? postcode String? lat Float? lng Float? preferredDates Json @default("[]") extractedFields Json @default("{}") missingFields Json @default("[]") jobVariables Json @default("{}") riskFlags Json @default("[]") quotedPrice Decimal? priceConfidence Float? suggestedNextAction String? aiSummary String? lostReason String? nextFollowUpAt DateTime? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) contact Contact? @relation(fields:[contactId], references:[id]) service Service? @relation(fields:[serviceId], references:[id]) messages Message[] quotes Quote[] jobs Job[] approvals ApprovalRequest[] outboundMessages OutboundMessage[] }
model Quote { id String @id @default(cuid()) businessId String leadId String serviceId String? price Decimal currency String @default("GBP") priceType PriceType confidence Float messageText String status QuoteStatus @default(draft) sentAt DateTime? expiresAt DateTime? createdAt DateTime @default(now()) business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) lead Lead @relation(fields:[leadId], references:[id], onDelete:Cascade) service Service? @relation(fields:[serviceId], references:[id]) }
model Job { id String @id @default(cuid()) businessId String leadId String contactId String serviceId String? calendarEventId String? title String description String? address String? postcode String? lat Float? lng Float? scheduledStart DateTime scheduledEnd DateTime durationMinutes Int travelBufferMinutes Int @default(20) price Decimal currency String @default("GBP") status JobStatus @default(scheduled) paymentStatus PaymentStatus @default(unpaid) completionPromptSentAt DateTime? completedAt DateTime? completionNotes String? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) lead Lead @relation(fields:[leadId], references:[id]) contact Contact @relation(fields:[contactId], references:[id]) service Service? @relation(fields:[serviceId], references:[id]) messages Message[] approvals ApprovalRequest[] outboundMessages OutboundMessage[] invoices Invoice[] reviewRequests ReviewRequest[] }
model ApprovalRequest { id String @id @default(cuid()) businessId String leadId String? jobId String? type ApprovalType summary String proposedMessage String? proposedSlotStart DateTime? proposedSlotEnd DateTime? riskLevel RiskLevel @default(low) actions Json @default("[]") status ApprovalStatus @default(pending) ownerEditedMessage String? expiresAt DateTime? createdAt DateTime @default(now()) updatedAt DateTime @updatedAt business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) lead Lead? @relation(fields:[leadId], references:[id]) job Job? @relation(fields:[jobId], references:[id]) outboundMessages OutboundMessage[] }
model OutboundMessage { id String @id @default(cuid()) businessId String contactId String? leadId String? jobId String? approvalRequestId String? channel MessageChannel recipientHandle String bodyText String payload Json? requiresTemplate Boolean @default(false) templateName String? idempotencyKey String @unique status OutboundStatus @default(queued) providerMessageId String? retryCount Int @default(0) lastError String? scheduledFor DateTime? sentAt DateTime? createdAt DateTime @default(now()) business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) contact Contact? @relation(fields:[contactId], references:[id]) lead Lead? @relation(fields:[leadId], references:[id]) job Job? @relation(fields:[jobId], references:[id]) approvalRequest ApprovalRequest? @relation(fields:[approvalRequestId], references:[id]) }
model Invoice { id String @id @default(cuid()) businessId String jobId String contactId String invoiceNumber String customerName String customerEmail String? customerPhone String? billingAddress String? lineItems Json subtotal Decimal taxAmount Decimal @default(0) total Decimal currency String @default("GBP") status InvoiceStatus @default(draft) paymentLink String? stripeInvoiceId String? stripePaymentLinkId String? pdfUrl String? dueDate DateTime? sentAt DateTime? paidAt DateTime? createdAt DateTime @default(now()) business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) job Job @relation(fields:[jobId], references:[id]) contact Contact @relation(fields:[contactId], references:[id]) @@unique([businessId, invoiceNumber]) }
model ReviewRequest { id String @id @default(cuid()) businessId String jobId String contactId String channel MessageChannel reviewLink String messageText String status ReviewStatus @default(draft) sentAt DateTime? createdAt DateTime @default(now()) business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) job Job @relation(fields:[jobId], references:[id]) contact Contact @relation(fields:[contactId], references:[id]) }
model ActivityLog { id String @id @default(cuid()) businessId String actorType ActorType actorId String? entityType String entityId String action String metadata Json? createdAt DateTime @default(now()) business Business @relation(fields:[businessId], references:[id], onDelete:Cascade) }
